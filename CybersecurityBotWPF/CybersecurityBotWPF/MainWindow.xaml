<Window x:Class="CybersecurityBotWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CybersecurityBotWPF"
        mc:Ignorable="d"
        Title="Cybersecurity Awareness Chatbot" Height="750" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E">

    <Window.Resources>
        <!-- Message Templates -->
        <DataTemplate x:Key="UserMessageTemplate">
            <Border Background="#2D2D44" CornerRadius="12" Margin="5,5,50,5" Padding="12,8">
                <TextBlock Text="{Binding Text}" Foreground="White" FontSize="14" TextWrapping="Wrap"/>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="BotMessageTemplate">
            <Border Background="#1E3A5F" CornerRadius="12" Margin="50,5,5,5" Padding="12,8">
                <TextBlock Text="{Binding Text}" Foreground="#E0E0E0" FontSize="14" TextWrapping="Wrap"/>
            </Border>
        </DataTemplate>

        <!-- Message Template Selector -->
        <local:MessageTemplateSelector x:Key="MessageTemplateSelector"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#16213E" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <TextBlock Text="🛡️" FontSize="28" Margin="0,0,10,0"/>
                    <StackPanel>
                        <TextBlock Text="CyberGuard" FontSize="22" FontWeight="Bold" Foreground="#00D4FF"/>
                        <TextBlock Text="Cybersecurity Awareness Bot" FontSize="12" Foreground="#8899AA"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Grid.Column="2">
                    <Button x:Name="btnStartQuiz" Content="📝 Quiz" Click="BtnStartQuiz_Click" 
                            Background="#2D2D44" Foreground="White" Padding="12,6" Margin="5,0"
                            BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="btnShowTasks" Content="📋 Tasks" Click="BtnShowTasks_Click"
                            Background="#2D2D44" Foreground="White" Padding="12,6" Margin="5,0"
                            BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="btnShowLog" Content="📜 Log" Click="BtnShowLog_Click"
                            Background="#2D2D44" Foreground="White" Padding="12,6" Margin="5,0"
                            BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="btnClearChat" Content="🗑️ Clear" Click="BtnClearChat_Click"
                            Background="#2D2D44" Foreground="White" Padding="12,6" Margin="5,0"
                            BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Chat Messages Area -->
        <ListBox x:Name="lstMessages" Grid.Row="1" 
                 Background="#1A1A2E" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ItemTemplateSelector="{StaticResource MessageTemplateSelector}">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Margin" Value="0,2"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <!-- Input Area -->
        <Border Grid.Row="2" Background="#16213E" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="txtInput" Grid.Column="0" 
                         Background="#2D2D44" Foreground="White" 
                         BorderThickness="0" Padding="12,10" FontSize="14"
                         TextWrapping="Wrap" MaxHeight="100"
                         KeyDown="TxtInput_KeyDown">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="20" BorderThickness="0">
                                            <ScrollViewer Margin="0" x:Name="PART_ContentHost"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <Button x:Name="btnSend" Grid.Column="1" Content="➤" 
                        Click="BtnSend_Click" Width="50" Height="50"
                        Background="#00D4FF" Foreground="#1A1A2E"
                        FontSize="22" BorderThickness="0" Margin="8,0,0,0"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="25" BorderThickness="0">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#00B8E6"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="#0D0D1A" Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="txtStatus" Grid.Column="0" Foreground="#667788" FontSize="11">
                    Status: Online • Ready to help
                </TextBlock>
                <TextBlock x:Name="txtConnectionStatus" Grid.Column="1" Foreground="#667788" FontSize="11" Margin="15,0">
                    🔒 Secure Connection
                </TextBlock>
                <TextBlock x:Name="txtTaskCount" Grid.Column="2" Foreground="#667788" FontSize="11" Margin="15,0,0,0">
                    Tasks: 0
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>